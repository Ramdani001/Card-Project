model Transaction {
  id                         String                       @id @default(uuid())
  invoice                    String                       @unique
  userId                     String
  subTotal                   Decimal                      @db.Decimal(15, 2)
  voucherAmount              Decimal                      @default(0) @db.Decimal(15, 2)
  shippingVoucherAmount      Decimal                      @default(0) @db.Decimal(15, 2)
  totalPrice                 Decimal                      @db.Decimal(15, 2)
  status                     TransactionStatus            @default(PENDING)
  paymentMethod              String?
  snapToken                  String?
  paymentExpiryTime          DateTime?
  snapRedirect               String?
  customerName               String?
  customerEmail              String?
  deliveryMethod             DeliveryMethod               @default(SHIP)
  shopId                     String?
  isActive                   Boolean                      @default(true)
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime                     @updatedAt
  voucherId                  String?
  expedition                 String?
  courierName                String?
  courierCode                String?
  resi                       String?
  shippingCost               Decimal                      @default(0) @db.Decimal(15, 2)
  shop                       Shop?                        @relation(fields: [shopId], references: [id])
  paymentLogs                PaymentLog[]
  user                       User                         @relation(fields: [userId], references: [id])
  voucher                    Voucher?                     @relation(fields: [voucherId], references: [id])
  items                      TransactionItem[]
  statusLogs                 TransactionStatusLog[]
  transactionShipmentAddress TransactionShipmentAddress[]
  transactionVouchers        TransactionVoucher[]
}

model TransactionVoucher {
  id            String               @id @default(uuid())
  transactionId String
  voucherId     String
  voucherCode   String
  voucherAmount Decimal              @default(0) @db.Decimal(15, 2)
  usageCategory VoucherUsageCategory @default(CARD)

  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  voucher     Voucher?    @relation(fields: [voucherId], references: [id])
  transaction Transaction @relation(fields: [transactionId], references: [id])
}

model TransactionShipmentAddress {
  id              String    @id @default(uuid())
  transactionId   String
  countryIsoCode  String
  countryName     String
  provinceCode    String
  provinceName    String
  cityCode        String
  cityName        String
  subDistrictCode String
  subDistrictName String
  villageCode     String
  villageName     String
  postalCode      String
  address         String
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime? @updatedAt

  transaction Transaction @relation(fields: [transactionId], references: [id])
  country     Country     @relation(fields: [countryIsoCode], references: [isoCode])
  province    Province    @relation(fields: [provinceCode], references: [code])
  city        City        @relation(fields: [cityCode], references: [code])
  subDistrict SubDistrict @relation(fields: [subDistrictCode], references: [code])
  village     Village     @relation(fields: [villageCode], references: [code])
}

model TransactionItem {
  id            String      @id @default(uuid())
  transactionId String
  cardId        String?
  productName   String
  productPrice  Decimal     @db.Decimal(15, 2)
  quantity      Int
  subTotal      Decimal     @db.Decimal(15, 2)
  skuSnapshot   String?
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  card          Card?       @relation(fields: [cardId], references: [id], onDelete: SetNull)
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model TransactionStatusLog {
  id             String             @id @default(uuid())
  transactionId  String
  status         TransactionStatus
  previousStatus TransactionStatus?
  note           String?
  isActive       Boolean            @default(true)
  createdBy      String?
  createdAt      DateTime           @default(now())
  transaction    Transaction        @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model PaymentLog {
  id          String      @id @default(uuid())
  orderId     String
  provider    String      @default("MIDTRANS")
  status      String?
  rawPayload  Json
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  transaction Transaction @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

model Courier {
  id          String   @id @default(uuid())
  courierCode String
  description String?
  status      Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([courierCode, isActive])
}

model Cart {
  id        String     @id @default(uuid())
  userId    String
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  cardId    String
  quantity  Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@unique([cartId, cardId, isActive])
}

model ErrorLog {
  id      String  @id @default(cuid())
  level   String  @default("ERROR")
  service String
  message String  @db.Text
  stack   String? @db.Text
  context Json?

  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}

enum TransactionStatus {
  PENDING
  PAID
  PROCESSED
  SHIPPED
  COMPLETED
  CANCELLED
  FAILED
  REFUNDED
  EXPIRED
}

enum DeliveryMethod {
  SHIP
  PICKUP
}
