model Role {
  id                       String                   @id @default(uuid())
  name                     String
  canAccessDashboard       Boolean                  @default(false)
  isActive                 Boolean                  @default(true)
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  cardCategoryRoleAccesses CardCategoryRoleAccess[]
  roleApiAccesses          RoleApiAccess[]
  roleMenuAccesses         RoleMenuAccess[]
  users                    User[]
  roleNotifications        RoleNotification[]
  voucherRoles             VoucherRole[]

  @@unique([name, isActive])
}

model CardCategoryRoleAccess {
  id         String   @id @default(uuid())
  roleId     String
  categoryId String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  category   Category @relation(fields: [categoryId], references: [id])
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, categoryId, isActive])
}

model RoleMenuAccess {
  id        String   @id @default(uuid())
  roleId    String
  menuId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  menu      Menu     @relation(fields: [menuId], references: [id])
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, menuId, isActive])
}

model RoleApiAccess {
  id            String      @id @default(uuid())
  roleId        String
  apiEndpointId String
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  canCreate     Boolean     @default(false)
  canDelete     Boolean     @default(false)
  canRead       Boolean     @default(false)
  canUpdate     Boolean     @default(false)
  apiEndpoint   ApiEndpoint @relation(fields: [apiEndpointId], references: [id])
  role          Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, apiEndpointId, isActive])
  @@index([roleId])
}

model ApiEndpoint {
  id              String          @id @default(uuid())
  url             String
  description     String?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  roleApiAccesses RoleApiAccess[]

  @@unique([url, isActive])
}

model User {
  id              String         @id @default(uuid())
  email           String
  password        String
  name            String?
  phone           String?
  avatar          String?
  roleId          String?
  facebookUrl     String?
  instagramUrl    String?
  twitterUrl      String?
  countryIsoCode  String?
  provinceCode    String?
  cityCode        String?
  subDistrictCode String?
  villageCode     String?
  postalCode      String?
  address         String?
  isVerified      Boolean        @default(false)
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  carts           Cart[]
  transactions    Transaction[]
  role            Role?          @relation(fields: [roleId], references: [id])
  notifications   Notification[]
  otps            Otp[]
  country         Country?       @relation(fields: [countryIsoCode], references: [isoCode])
  province        Province?      @relation(fields: [provinceCode], references: [code])
  city            City?          @relation(fields: [cityCode], references: [code])
  subDistrict     SubDistrict?   @relation(fields: [subDistrictCode], references: [code])
  village         Village?       @relation(fields: [villageCode], references: [code])

  @@unique([email, isActive])
}

model Otp {
  id     String  @id @default(uuid())
  code   String
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   OtpType @default(REGISTRATION)

  expiresAt DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([code])
}

enum OtpType {
  REGISTRATION
  FORGOT_PASSWORD
}
