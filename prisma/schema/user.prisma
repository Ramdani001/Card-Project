model Role {
  id                       String                   @id @default(uuid())
  name                     String                   @unique
  canAccessDashboard       Boolean                  @default(false)
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  cardCategoryRoleAccesses CardCategoryRoleAccess[]
  roleApiAccesses          RoleApiAccess[]
  roleMenuAccesses         RoleMenuAccess[]
  users                    User[]
  roleNotifications        RoleNotification[]
  voucherRoles             VoucherRole[]
}

model CardCategoryRoleAccess {
  id         String   @id @default(uuid())
  roleId     String
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  category   Category @relation(fields: [categoryId], references: [id])
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, categoryId])
}

model RoleMenuAccess {
  id        String   @id @default(uuid())
  roleId    String
  menuId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  menu      Menu     @relation(fields: [menuId], references: [id])
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, menuId])
}

model RoleApiAccess {
  id            String      @id @default(uuid())
  roleId        String
  apiEndpointId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  canCreate     Boolean     @default(false)
  canDelete     Boolean     @default(false)
  canRead       Boolean     @default(false)
  canUpdate     Boolean     @default(false)
  apiEndpoint   ApiEndpoint @relation(fields: [apiEndpointId], references: [id])
  role          Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, apiEndpointId])
  @@index([roleId])
}

model ApiEndpoint {
  id              String          @id @default(uuid())
  url             String          @unique
  description     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  roleApiAccesses RoleApiAccess[]
}

model User {
  id              String         @id @default(uuid())
  email           String         @unique
  password        String
  name            String?
  phone           String?
  avatar          String?
  roleId          String?
  facebookUrl     String?
  instagramUrl    String?
  twitterUrl      String?
  countryIsoCode  String?
  provinceCode    String?
  cityCode        String?
  subDistrictCode String?
  villageCode     String?
  postalCode      String?
  address         String?
  isVerified      Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  cardHistories   CardHistory[]
  carts           Cart[]
  transactions    Transaction[]
  role            Role?          @relation(fields: [roleId], references: [id])
  notifications   Notification[]
  otps            Otp[]
  country         Country?       @relation(fields: [countryIsoCode], references: [isoCode])
  province        Province?      @relation(fields: [provinceCode], references: [code])
  city            City?          @relation(fields: [cityCode], references: [code])
  subDistrict     SubDistrict?   @relation(fields: [subDistrictCode], references: [code])
  village         Village?       @relation(fields: [villageCode], references: [code])
}

model Otp {
  id     String  @id @default(uuid())
  code   String
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   OtpType @default(REGISTRATION)

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([code])
}

enum OtpType {
  REGISTRATION
  FORGOT_PASSWORD
}
