model Event {
  id        String       @id @default(uuid())
  title     String
  slug      String
  content   String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  images    EventImage[]

  @@unique([slug, isActive])
}

model EventImage {
  id           String   @id @default(uuid())
  url          String
  eventId      String
  isPrimary    Boolean  @default(false)
  fileName     String
  mimeType     String
  originalName String
  path         String
  size         Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model BannerImage {
  id           String   @id @default(uuid())
  startDate    DateTime
  endDate      DateTime
  url          String
  path         String
  originalName String
  fileName     String
  mimeType     String
  size         Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  link         String?
}

model Article {
  id        String         @id @default(uuid())
  title     String
  content   String
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  slug      String
  images    ArticleImage[]

  @@unique([slug, isActive])
}

model ArticleImage {
  id           String   @id @default(uuid())
  articleId    String
  isPrimary    Boolean  @default(false)
  url          String
  path         String
  originalName String
  fileName     String
  mimeType     String
  size         Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  article      Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model Discount {
  id            String        @id @default(uuid())
  name          String
  value         Decimal       @db.Decimal(10, 2)
  type          DiscountType
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  cards         Card[]
  cardHistories CardHistory[]
}

model Voucher {
  id                    String                @id @default(uuid())
  code                  String
  name                  String
  description           String?
  type                  DiscountType
  usageCategory         VoucherUsageCategory  @default(CARD)
  value                 Decimal               @db.Decimal(10, 2)
  minPurchase           Decimal?              @db.Decimal(15, 2)
  maxDiscount           Decimal?              @db.Decimal(15, 2)
  stock                 Int?
  usedCount             Int                   @default(0)
  startDate             DateTime
  endDate               DateTime
  isActive              Boolean               @default(true)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  transactions          Transaction[]
  voucherCardCategories VoucherCardCategory[]
  voucherCards          VoucherCard[]
  voucherRoles          VoucherRole[]
  transactionVouchers   TransactionVoucher[]

  @@unique([code, isActive])
  @@index([code])
  @@index([startDate, endDate])
}

model VoucherCardCategory {
  id             String @id @default(uuid())
  voucherId      String
  cardCategoryId String

  voucher      Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  cardCategory Category @relation(fields: [cardCategoryId], references: [id], onDelete: Cascade)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VoucherCard {
  id        String @id @default(uuid())
  voucherId String
  cardId    String

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  card    Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VoucherRole {
  id        String @id @default(uuid())
  voucherId String
  roleId    String

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DiscountType {
  NOMINAL
  PERCENTAGE
}

enum VoucherUsageCategory {
  CARD
  SHIPPING_COST
}
