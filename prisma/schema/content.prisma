model Event {
  id        String       @id @default(uuid())
  title     String
  slug      String       @unique
  content   String
  startDate DateTime
  endDate   DateTime
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  images    EventImage[]
}

model EventImage {
  id           String   @id @default(uuid())
  url          String
  eventId      String
  createdAt    DateTime @default(now())
  isPrimary    Boolean  @default(false)
  fileName     String
  mimeType     String
  originalName String
  path         String
  size         Int
  updatedAt    DateTime @updatedAt
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model BannerImage {
  id           String   @id @default(uuid())
  startDate    DateTime
  endDate      DateTime
  url          String
  path         String
  originalName String
  fileName     String
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  link         String?
}

model Article {
  id        String         @id @default(uuid())
  title     String
  content   String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  slug      String         @unique
  images    ArticleImage[]
}

model ArticleImage {
  id           String   @id @default(uuid())
  articleId    String
  isPrimary    Boolean  @default(false)
  url          String
  path         String
  originalName String
  fileName     String
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  article      Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model Discount {
  id            String        @id @default(uuid())
  name          String
  value         Decimal       @db.Decimal(10, 2)
  type          DiscountType
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  cards         Card[]
  cardHistories CardHistory[]
}

model Voucher {
  id                    String                @id @default(uuid())
  code                  String                @unique
  name                  String
  description           String?
  type                  DiscountType
  value                 Decimal               @db.Decimal(10, 2)
  minPurchase           Decimal?              @db.Decimal(15, 2)
  maxDiscount           Decimal?              @db.Decimal(15, 2)
  stock                 Int?
  usedCount             Int                   @default(0)
  startDate             DateTime
  endDate               DateTime
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  transactions          Transaction[]
  voucherCardCategories VoucherCardCategory[]
  voucherCards          VoucherCard[]
  voucherRoles          VoucherRole[]

  @@index([code])
  @@index([startDate, endDate])
}

model VoucherCardCategory {
  id             String @id @default(uuid())
  voucherId      String
  cardCategoryId String

  voucher      Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  cardCategory Category @relation(fields: [cardCategoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VoucherCard {
  id        String @id @default(uuid())
  voucherId String
  cardId    String

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  card    Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VoucherRole {
  id        String @id @default(uuid())
  voucherId String
  roleId    String

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DiscountType {
  NOMINAL
  PERCENTAGE
}
