model Country {
    id                           String                       @id @default(uuid())
    name                         String
    isoCode                      String                       @unique
    isActive                     Boolean                      @default(true)
    createdAt                    DateTime                     @default(now())
    updatedAt                    DateTime                     @updatedAt
    provinces                    Province[]
    transactionShipmentAddresses TransactionShipmentAddress[]
    users                        User[]
    shops                        Shop[]
}

model Province {
    id                           String                       @id @default(uuid())
    name                         String
    code                         String                       @unique
    countryId                    String
    isActive                     Boolean                      @default(true)
    createdAt                    DateTime                     @default(now())
    updatedAt                    DateTime                     @updatedAt
    country                      Country                      @relation(fields: [countryId], references: [id])
    cities                       City[]
    transactionShipmentAddresses TransactionShipmentAddress[]
    users                        User[]
    shops                        Shop[]
}

model City {
    id                           String                       @id @default(uuid())
    name                         String
    code                         String                       @unique
    provinceId                   String
    isActive                     Boolean                      @default(true)
    createdAt                    DateTime                     @default(now())
    updatedAt                    DateTime                     @updatedAt
    province                     Province                     @relation(fields: [provinceId], references: [id])
    subDistricts                 SubDistrict[]
    transactionShipmentAddresses TransactionShipmentAddress[]
    users                        User[]
    shops                        Shop[]
}

model SubDistrict {
    id                           String                       @id @default(uuid())
    name                         String
    code                         String                       @unique
    cityId                       String
    isActive                     Boolean                      @default(true)
    createdAt                    DateTime                     @default(now())
    updatedAt                    DateTime                     @updatedAt
    city                         City                         @relation(fields: [cityId], references: [id])
    villages                     Village[]
    transactionShipmentAddresses TransactionShipmentAddress[]
    users                        User[]
    shops                        Shop[]

    @@unique([code, isActive])
}

model Village {
    id                           String                       @id @default(uuid())
    name                         String
    code                         String                       @unique
    subDistrictId                String
    isActive                     Boolean                      @default(true)
    createdAt                    DateTime                     @default(now())
    updatedAt                    DateTime                     @updatedAt
    subDistrict                  SubDistrict                  @relation(fields: [subDistrictId], references: [id])
    transactionShipmentAddresses TransactionShipmentAddress[]
    users                        User[]
    shops                        Shop[]

    @@unique([code, isActive])
}
