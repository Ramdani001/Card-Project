model AppConfig {
    id        String   @id @default(uuid())
    key       String
    value     String
    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([key, isActive])
}

model Menu {
    id               String           @id @default(uuid())
    label            String
    url              String?
    icon             String?
    order            Int              @default(0)
    parentId         String?
    isActive         Boolean          @default(true)
    createdAt        DateTime         @default(now())
    updatedAt        DateTime         @updatedAt
    isDashboardMenu  Boolean          @default(true)
    parent           Menu?            @relation("MenuToSubMenu", fields: [parentId], references: [id], onDelete: Cascade)
    subMenus         Menu[]           @relation("MenuToSubMenu")
    roleMenuAccesses RoleMenuAccess[]
}

model Shop {
    id              String        @id @default(uuid())
    name            String
    isMainShop      Boolean       @default(false)
    countryIsoCode  String
    countryName     String
    provinceCode    String
    provinceName    String
    cityCode        String
    cityName        String
    subDistrictCode String
    subDistrictName String
    villageCode     String
    villageName     String
    postalCode      String
    address         String
    isActive        Boolean       @default(true)
    createdAt       DateTime      @default(now())
    updatedAt       DateTime      @updatedAt
    transactions    Transaction[]

    country     Country     @relation(fields: [countryIsoCode], references: [isoCode])
    province    Province    @relation(fields: [provinceCode], references: [code])
    city        City        @relation(fields: [cityCode], references: [code])
    subDistrict SubDistrict @relation(fields: [subDistrictCode], references: [code])
    village     Village     @relation(fields: [villageCode], references: [code])
}
